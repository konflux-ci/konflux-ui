{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prConcurrentLimit": 5,
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "description": "Automerge minor and patch updates for package versions",
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
