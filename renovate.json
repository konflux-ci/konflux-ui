{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "prConcurrentLimit": 5,
  "minimumReleaseAge": "7 days",
  "packageRules": [
    {
      "description": "Automerge minor, patch, and digest updates for package versions",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    }
  ]
}
